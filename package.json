{
  "name": "nirik",
  "version": "1.0.0",
  "description": "Automated PR reviews with AI (Gemini), GitHub webhooks, and Redis queue",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "test": "npm run codecheck",
    "prepare": "husky",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "preparepush": "npm run lint && npm run format",
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "codecheck": "npm run format:check && npm run lint"
  },
  "keywords": [
    "github",
    "pull-request",
    "code-review",
    "gemini",
    "ai",
    "webhook",
    "redis"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/imabhinavdev/nirik.git"
  },
  "homepage": "https://github.com/imabhinavdev/nirik#readme",
  "bugs": {
    "url": "https://github.com/imabhinavdev/nirik/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.30.3",
  "dependencies": {
    "@google/genai": "^1.43.0",
    "bullmq": "^5.34.5",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "ioredis": "^5.4.1",
    "openai": "^4.104.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.3",
    "eslint": "^10.0.2",
    "globals": "^17.4.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1"
  }
}
